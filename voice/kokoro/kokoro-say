#!/bin/sh
# VULCAN · PART 7 — KOKORO_BIN entrypoint. Runs the Kokoro TTS CLI inside its
# python3.11 venv so the voice organ can spawn it directly (no activation needed):
#     kokoro-say "<text>" -o <out.wav>
# Point KOKORO_BIN at this file in .env.
DIR="$(cd "$(dirname "$0")" && pwd)"
exec "$DIR/venv/bin/python" "$DIR/say.py" "$@"
