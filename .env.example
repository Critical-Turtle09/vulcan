# VULCAN — ORGAN 1 (voice) environment. Copy to .env and fill in.
# .env is gitignored; never commit real keys.

# ElevenLabs text-to-speech. Without a key the voice organ fails soft:
# the HUD shows "VOICE OFFLINE" and keys 1-4 still drive the orb.
ELEVENLABS_API_KEY=
# Optional — defaults to a stock ElevenLabs voice if unset.
ELEVENLABS_VOICE_ID=

# Local whisper.cpp for the wake word + transcription. Point these at your
# build. If unset/missing, live mic wake is disabled (test mode still works).
WHISPER_BIN=
WHISPER_MODEL=

# Set to 1 to run the voice loop in synthetic test mode (no mic / no network).
VULCAN_VOICE_TEST=0
