# VULCAN — ORGAN 1 (voice) environment. Copy to .env and fill in.
# .env is gitignored; never commit real keys.

# ElevenLabs text-to-speech (voice "VULCAN 1"). Without a key the voice organ
# fails soft down the chain (kokoro -> say) and the HUD still drives the orb.
ELEVENLABS_API_KEY=
# Optional legacy fallback. The VULCAN 1 voice id lives in tokens.json (voice.id);
# this env var is only used if that token is empty, then a stock voice.
ELEVENLABS_VOICE_ID=

# S2 THE TRIGGER — EARS CHAIN. Primary STT is the Wispr Flow REST API. Get a key
# from the Wispr Flow dashboard (platform-api.wisprflow.ai — sign in, open the API /
# developer settings, create a key). Passed as `Authorization: Bearer` main-side only;
# never logged, never committed. Empty / offline / API error -> local whisper below,
# seamlessly (the drop is tagged [EARS·LOCAL]). Endpoint + params live in tokens.json
# voice.ears.wispr.*.
VULCAN_WISPR_KEY=

# Local whisper.cpp for the wake word + transcription — the ears-chain FALLBACK (and
# the primary when no VULCAN_WISPR_KEY). Point these at your build. If unset/missing
# AND no Wispr key, live mic is disabled (test mode still works).
WHISPER_BIN=
WHISPER_MODEL=

# Set to 1 to run the voice loop in synthetic test mode (no mic / no network).
VULCAN_VOICE_TEST=0

# TTS provider (ORGAN 1.5). Leave blank for auto-failover elevenlabs -> kokoro ->
# say. Force one with: elevenlabs | kokoro | say.
VULCAN_TTS_PROVIDER=
# Local Kokoro TTS (PART 7): run `voice/kokoro/setup.sh` (python3.11 venv +
# model download), then point KOKORO_BIN at the CLI ( `$KOKORO_BIN "text" -o out.wav` ).
# With no ELEVENLABS_API_KEY the provider chain uses this local neural voice.
KOKORO_BIN=./voice/kokoro/kokoro-say
KOKORO_VOICE=bm_george

# Override the renderer URL Electron loads (default http://localhost:5273/).
VULCAN_DEV_URL=

# B5R FIRST MISSION — Vercel read-only deploy eye (optional). VULCAN reports
# deployment health via `npx vercel`; the token is passed to the CLI as VERCEL_TOKEN
# (never argv, never logged, never committed). Empty -> DEPLOY reads "not connected".
# Pair with mission.vercel_project in tokens.local.json.
VULCAN_VERCEL_TOKEN=
